# 站点公开配置
# 本地开发使用 http://localhost:13100；生产部署改为 https://ovoforge.com
NEXT_PUBLIC_SITE_URL=http://localhost:13100
NEXT_PUBLIC_CONTACT_EMAIL=h5gamelog@gmail.com

# Google Analytics 4 Measurement ID（可选）
# 本地开发留空或注释掉，不加载 GA 脚本；生产环境填写 G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Cloudflare Web Analytics token（可选）
# 隐私友好、无 Cookie，不需要同意横幅；在 Cloudflare 控制台 Web Analytics 中获取
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# 版主口令
MOD_PASSWORD=your_mod_password

# 联系表单 Gmail API / OAuth 2.0 配置（如需邮件发送，取消注释并填写）
# 配置步骤：
#   1. 在 Google Cloud Console 创建项目并启用 Gmail API
#   2. 创建 OAuth 2.0 客户端 ID（Web 应用类型），获取 Client ID 与 Client Secret
#   3. 获取 refresh_token（二选一）：
#      a) 使用项目脚本：取消下方 GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET 注释后运行
#         pnpm tsx scripts/gmail-auth.ts
#         按提示在浏览器授权，将返回的 refresh_token 填入下方
#      b) 使用 OAuth Playground：https://developers.google.com/oauthplayground
#         scope: https://www.googleapis.com/auth/gmail.send
#   4. 将下方值替换为真实凭据
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REFRESH_TOKEN=your_refresh_token
# GOOGLE_SENDER_EMAIL=h5gamelog@gmail.com
# GOOGLE_REDIRECT_URI=http://localhost:13100
#   线上部署时，将 GOOGLE_REDIRECT_URI 改为你的真实域名，例如 https://ovoforge.com
#   同时需要在 Google Cloud Console 的 OAuth 2.0 客户端 ID 里添加该重定向 URI

# 算法后端端口（默认 14100，可不配置）
# ALGO_PORT=14100

# Upstash Redis（用于 view/like 统计持久化；本地开发可留空，回退到文件系统）
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# AI 服务
MOONSHOT_API_KEY=your_moonshot_api_key
